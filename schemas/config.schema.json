{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/lidar-label-tool/config.schema.json",
  "title": "LiDAR Label Tool configuration",
  "type": "object",
  "required": [
    "classes",
    "source_class_mappings",
    "point_cloud",
    "dataset",
    "calibration",
    "editing",
    "workflow",
    "performance",
    "views"
  ],
  "properties": {
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "color", "default_size"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "default_size": {
            "type": "array",
            "prefixItems": [
              { "type": "number", "exclusiveMinimum": 0 },
              { "type": "number", "exclusiveMinimum": 0 },
              { "type": "number", "exclusiveMinimum": 0 }
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "shortcut": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "source_class_mappings": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "point_cloud": {
      "type": "object",
      "required": ["format", "max_render_points", "intensity_normalization"],
      "properties": {
        "format": { "const": "manifest" },
        "max_render_points": { "type": "integer", "minimum": 1000 },
        "intensity_normalization": {
          "enum": ["auto", "zero_one", "zero_255", "none"]
        }
      },
      "additionalProperties": false
    },
    "dataset": {
      "type": "object",
      "required": ["layout", "synchronization", "timestamp_tolerance_ms"],
      "properties": {
        "layout": { "enum": ["auto", "device_centric", "frame_centric_waymo"] },
        "synchronization": {
          "enum": ["manifest_or_exact_stem", "index", "exact_stem", "timestamp_nearest"]
        },
        "timestamp_tolerance_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "calibration": {
      "type": "object",
      "required": [
        "mode",
        "reference_frame",
        "primary_lidar",
        "merge_lidars_when_enabled",
        "manual_adjustment_enabled"
      ],
      "properties": {
        "mode": { "enum": ["auto", "on", "off"] },
        "reference_frame": { "type": "string", "minLength": 1 },
        "primary_lidar": { "type": ["string", "null"] },
        "merge_lidars_when_enabled": { "type": "boolean" },
        "manual_adjustment_enabled": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "editing": {
      "type": "object",
      "required": [
        "move_step_m",
        "fine_move_step_m",
        "resize_step_m",
        "yaw_step_deg",
        "carry_created_boxes_forward",
        "autosave_on_frame_change",
        "recovery_interval_s",
        "history_limit"
      ],
      "properties": {
        "move_step_m": { "type": "number", "exclusiveMinimum": 0 },
        "fine_move_step_m": { "type": "number", "exclusiveMinimum": 0 },
        "resize_step_m": { "type": "number", "exclusiveMinimum": 0 },
        "yaw_step_deg": { "type": "number", "exclusiveMinimum": 0 },
        "carry_created_boxes_forward": { "type": "boolean" },
        "autosave_on_frame_change": { "type": "boolean" },
        "recovery_interval_s": { "type": "integer", "minimum": 5 },
        "history_limit": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": ["session_lock", "detect_external_changes", "default_frame_status"],
      "properties": {
        "session_lock": { "type": "boolean" },
        "detect_external_changes": { "type": "boolean" },
        "default_frame_status": {
          "enum": ["unvisited", "in_progress", "reviewed", "skipped"]
        }
      },
      "additionalProperties": false
    },
    "performance": {
      "type": "object",
      "required": ["prefetch_frames", "max_cache_mb", "render_quality"],
      "properties": {
        "prefetch_frames": { "type": "integer", "minimum": 0, "maximum": 4 },
        "max_cache_mb": { "type": "integer", "minimum": 128 },
        "render_quality": { "enum": ["auto", "high", "performance"] }
      },
      "additionalProperties": false
    },
    "views": {
      "type": "object",
      "required": [
        "side_view",
        "point_size",
        "box_line_width",
        "point_color_mode",
        "uniform_point_color",
        "camera_view_mode",
        "preserve_view_across_frames",
        "auto_focus_selection",
        "show_object_labels",
        "show_source_camera_labels",
        "show_projected_lidar_labels",
        "show_live_projection",
        "show_bev_auxiliary",
        "show_side_auxiliary",
        "object_detail_margin_m"
      ],
      "properties": {
        "side_view": { "enum": ["xz", "yz"] },
        "point_size": { "type": "number", "exclusiveMinimum": 0 },
        "box_line_width": { "type": "number", "minimum": 0.5, "maximum": 8.0 },
        "point_color_mode": { "enum": ["sensor", "height", "intensity", "uniform"] },
        "uniform_point_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "camera_view_mode": { "const": "single_select" },
        "preserve_view_across_frames": { "type": "boolean" },
        "auto_focus_selection": { "type": "boolean" },
        "show_object_labels": { "type": "boolean" },
        "show_source_camera_labels": { "type": "boolean" },
        "show_projected_lidar_labels": { "type": "boolean" },
        "show_live_projection": { "type": "boolean" },
        "show_bev_auxiliary": { "type": "boolean" },
        "show_side_auxiliary": { "type": "boolean" },
        "object_detail_margin_m": { "type": "number", "minimum": 0.5, "maximum": 20.0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
